SLACK_BOT_TOKEN=your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=your-app-token-here

# Slack Channel ID, week5ver
SLACK_CHANNEL_ID=CXXXXXXXXXX
# Slack List ID, week5ver-2026상반기
SLACK_LIST_ID=FXXXXXXXXXX

# 봇 표시 이름 / 아이콘 (chat:write.customize 스코프 필요)
# 공개 접근 가능한 이미지 URL 입력 (비워두면 기본 봇 아이콘 사용)
SLACK_COLLECTOR_ICON_URL=https://example.com/week5ver-collector.png
SLACK_UPDATOR_ICON_URL=https://example.com/week5ver-updator.png
SLACK_NOTIFIER_ICON_URL=https://example.com/week5ver-notifier.png

# Slack List Column ID
# python debug_columns.py 실행 후 확인한 값을 입력
# todo_completed (todo_completed)
SLACK_LIST_COL_TODO_COMPLETED=Col00
# todo_assignee (person)
SLACK_LIST_COL_ASSIGNEE=Col01
# todo_due_date (date)
SLACK_LIST_COL_DEADLINE=Col02
# name (text)
SLACK_LIST_COL_TITLE=ColXXXXXXXXX
# 주차 (select)
SLACK_LIST_COL_WEEK=ColXXXXXXXXX
# updated_at (timestamp)
SLACK_LIST_COL_UPDATED_AT=ColXXXXXXXXX
# 인증자료 (attachment)
SLACK_LIST_COL_PROOF=ColXXXXXXXXX
# 한 줄 회고 (text)
SLACK_LIST_COL_RETRO=ColXXXXXXXXX

# 주차 SELECT 옵션 ID
# python debug_columns.py 실행 후 확인한 값을 입력
SLACK_LIST_OPT_DEMO=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK1=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK2=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK3=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK4=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK5=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK6=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK7=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK8=OptXXXXXXXXX
SLACK_LIST_OPT_WEEK9=OptXXXXXXXXX
